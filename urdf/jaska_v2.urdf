  <!-- Unitree L2 Lidar Optical Frame (matches real hardware frame name) -->
  <link name="unilidar_lidar"/>
  <joint name="unitree_lidar_optical_joint" type="fixed">
    <parent link="unitree_lidar_link"/>
    <child link="unilidar_lidar"/>
    <origin rpy="0 0 0" xyz="0 0 0.030"/>
  </joint>

  <!-- Gazebo 3D Lidar Sensor Plugin for Unitree L2 -->
  <gazebo reference="unitree_lidar_link">
    <material>Gazebo/Black</material>
    <sensor name="unitree_l2_lidar" type="gpu_lidar">
      <pose>0 0 0.030 0 0 0</pose>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>unilidar/cloud</topic>
      <gz_frame_id>unilidar_lidar</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>1800</samples>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
            <resolution>1.0</resolution>
          </horizontal>
          <vertical>
            <samples>32</samples>
            <min_angle>-0.1047</min_angle>
            <!-- -6 degrees (downward) -->
            <max_angle>1.5708</max_angle>
            <!-- +90 degrees (upward dome) -->
            <resolution>1.0</resolution>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>30.0</max>
          <!-- Unitree L2 max range -->
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

