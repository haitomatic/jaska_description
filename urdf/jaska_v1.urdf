    <!-- Position at front of robot, angled 45 degrees -->
    <origin rpy="0 0.7853975 0" xyz="0.36000000000000004 -0.04 0.07500000000000001"/>
  </joint>
  <!-- ============================================== -->
  <!-- UNITREE L2 LIDAR                              -->
  <!-- ============================================== -->
  <!-- Unitree L2 Lidar Link (actual sensor) -->
  <link name="unitree_lidar_link">
    <visual>
      <origin rpy="0 0 0" xyz="-0.037 -0.037 -0.025"/>
      <geometry>
        <!-- Use actual Unitree L2 mesh from local meshes directory -->
        <mesh filename="package://jaska_description/meshes/jaska_v1/unitree_l2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="lidar_sensor">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <!-- Simplified collision geometry: approx 90mm diameter, 60mm height -->
        <cylinder length="0.060" radius="0.038"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.18"/>
      <!-- Unitree L2 is approximately 180g -->
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <!-- Unitree L2 Lidar Joint (mounted on top mounting point of sensor mount) -->
  <joint name="unitree_lidar_joint" type="fixed">
    <parent link="sensor_mount_base"/>
    <child link="unitree_lidar_link"/>
    <!-- Adjust these coordinates based on actual mounting point position on your STL -->
    <origin rpy="0 -0.7853975 0" xyz="0.010 0.042 0.135"/>
  </joint>
  <!-- Unitree L2 Lidar Optical Frame (matches real hardware frame name) -->
  <link name="unilidar_lidar"/>
  <joint name="unitree_lidar_optical_joint" type="fixed">
    <parent link="unitree_lidar_link"/>
    <child link="unilidar_lidar"/>
    <!-- Lidar optical frame at sensor center -->
    <origin rpy="0 0 0" xyz="0 0 0.030"/>
  </joint>
  <!-- Gazebo 3D Lidar Sensor Plugin for Unitree L2 -->
  <gazebo reference="unitree_lidar_link">
    <material>Gazebo/Black</material>
    <sensor name="unitree_l2_lidar" type="gpu_lidar">
      <pose>0 0 0.030 0 0 0</pose>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>unilidar/cloud</topic>
      <gz_frame_id>unilidar_lidar</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>1800</samples>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
            <resolution>1.0</resolution>
          </horizontal>
          <vertical>
            <samples>32</samples>
            <min_angle>-0.1047</min_angle>
            <!-- -6 degrees (downward) -->
            <max_angle>1.5708</max_angle>
            <!-- +90 degrees (upward dome) -->
            <resolution>1.0</resolution>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>30.0</max>
          <!-- Unitree L2 max range -->
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>
